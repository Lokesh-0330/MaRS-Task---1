# 1) Create directory and move into it
mkdir rover_mission
cd rover_mission

# 2) Create files
touch log1.txt log2.txt log3.txt

# 3) Rename file
mv log1.txt mission_log.txt

# 4) Find .log files
find . -name "*.log"

# 5) Display content
cat mission_log.txt

# 6) Find "ERROR"
grep "ERROR" mission_log.txt

# 7) Count lines
wc -l mission_log.txt

# 8) Show date
date

# 9) CPU usage
top

# 10) Shutdown in 10 minutes
shutdown +10